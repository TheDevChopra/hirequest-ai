generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  name          String?
  role          String    @default("CANDIDATE")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  jobApplications JobApplication[]
  resumes       ResumeVersion[]
  mockInterviews InterviewSession[]
  chatHistory   ChatHistory[]
  
  // Stealth Progression (Hidden from UI)
  level         Int       @default(1)
  currentXP     Int       @default(0)
  streakDays    Int       @default(0)
  lastActiveAt  DateTime?
}

model Profile {
  id             String  @id @default(uuid())
  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  about          String?
  location       String?
  preferredWorkType String? 
  currentRole    String?
  experienceLevel String?
  linkedinUrl    String?
  portfolioUrl   String?
  
  // Analytics
  profileViews      Int @default(0)
  searchAppearances Int @default(0)
  recruiterSaves    Int @default(0)
}

// ================= ATS / KANBAN =================

model JobApplication {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  company     String
  roleTitle   String
  location    String?
  salaryRange String?
  
  status      String   @default("Interested") // Interested, Applied, Recruiter_Viewed, Interview, Offer, Rejected, Accepted
  boardOrder  Int      @default(0) // For DND sorting within column
  
  notes       String?
  url         String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  timelineEvents ApplicationTimelineEvent[]
}

model ApplicationTimelineEvent {
  id             String   @id @default(uuid())
  applicationId  String
  application    JobApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  statusChangedTo String
  date           DateTime @default(now())
}

// ================= JOBS / OPPORTUNITIES =================

model Opportunity {
  id          String   @id @default(uuid())
  title       String   
  company     String
  location    String?
  remote      Boolean  @default(false)
  salaryMin   Int?
  salaryMax   Int?
  industry    String?
  experience  String?
  description String
  requirements String
  createdAt   DateTime @default(now())
}

// ================= AI & INTERVIEW =================

model ResumeVersion {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name        String
  content     String   // The parsed raw text
  
  // Intelligence Metrics
  atsScore        Int?
  readabilityScore Int?
  impactScore     Int?
  
  // JSON serialized analysis data to avoid excessive relational tables
  missingKeywords String? 
  foundKeywords   String? 
  improvementTips String?
  
  createdAt   DateTime @default(now())
}

model InterviewSession {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String   
  status      String   @default("Ongoing") 
  overallScore Int?
  createdAt   DateTime @default(now())
}

model ChatHistory {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        String   
  content     String
  createdAt   DateTime @default(now())
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  
  access_token       String?  
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
